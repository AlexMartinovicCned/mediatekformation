{% extends 'basefront.html.twig' %}

{% block title %}Playlist{% endblock %}

{% block body %}
    <h1>Playlist</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ playlist.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ playlist.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ playlist.description }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_playlist_admin_index') }}">back to list</a>

    <a href="{{ path('app_playlist_admin_edit', {'id': playlist.id}) }}">edit</a>

    {{ include('playlist_admin/_delete_form.html.twig') }}
{% endblock %}
