{% extends 'base.html.twig' %}

{% block title %}Formation{% endblock %}

{% block body %}
    <h1>Formation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ formation.id }}</td>
            </tr>
            <tr>
                <th>PublishedAt</th>
                <td>{{ formation.publishedAt ? formation.publishedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ formation.title }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ formation.description }}</td>
            </tr>
            <tr>
                <th>VideoId</th>
                <td>{{ formation.videoId }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_formation_admin_index') }}">back to list</a>

    <a href="{{ path('app_formation_admin_edit', {'id': formation.id}) }}">edit</a>

    {{ include('formation_admin/_delete_form.html.twig') }}
{% endblock %}
